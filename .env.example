# Upstream CRUD API the gateway proxies to (omni-campaign-studio-api)
UPSTREAM_API_URL=http://localhost:3000/api

# MongoDB (required) — stores api_keys, request_logs, usage_monthly
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=omni_campaign_gateway

# Upstash Redis REST (optional — falls back to in-memory for cache + rate limit)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# JWT for end-user tokens (studio frontend). Use EITHER a JWKS URL (recommended)
# OR a shared HS256 secret. Leave both empty to disable JWT auth (API keys only).
JWT_JWKS_URL=
JWT_SECRET=
JWT_ISSUER=
JWT_AUDIENCE=

# Rate limiting (per principal, sliding window of 1s). Defaults mirror AWS API GW.
RATELIMIT_RPS=1000
RATELIMIT_BURST=2000

# Default monthly cost budget (USD) applied to tenants without an explicit budget.
DEFAULT_MONTHLY_BUDGET_USD=50

# How many days to retain per-request telemetry logs (TTL index).
TELEMETRY_RETENTION_DAYS=30

# AI provider keys (BYOK — used by the /ai proxy; no markup on tokens).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Comma-separated list of allowed CORS origins (localhost:5173 is always allowed)
ALLOWED_ORIGINS=http://localhost:5173

# Environment
NODE_ENV=development

# Local dev server port (used by src/server.ts)
PORT=8787
