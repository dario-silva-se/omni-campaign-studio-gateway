# Production deploy on Vercel: see DEPLOY.md for the exact variables to set per
# project. In production these defaults (localhost) MUST be overridden.

# Upstream CRUD API the gateway proxies to (omni-campaign-studio-api).
# Trailing slashes are stripped automatically.
UPSTREAM_API_URL=http://localhost:3000/api

# Upstream request timeout in ms (a slow upstream fails fast as 504).
UPSTREAM_TIMEOUT_MS=15000

# MongoDB (required) — stores api_keys, request_logs, usage_monthly
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=omni_campaign_gateway

# Upstash Redis REST (optional — falls back to in-memory for cache + rate limit)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# JWT for end-user tokens (studio frontend). Use EITHER a JWKS URL (external IdP)
# OR a shared HS256 secret. JWT_SECRET also signs the access tokens issued by the
# gateway's own login (/_gw/auth). Leave all empty to disable JWT/login auth.
JWT_JWKS_URL=
JWT_SECRET=
JWT_ISSUER=
JWT_AUDIENCE=

# Login-issued token lifetimes.
ACCESS_TOKEN_TTL=30m
REFRESH_TOKEN_TTL_DAYS=7

# Rate limiting (per principal, sliding window of 1s). Defaults mirror AWS API GW.
RATELIMIT_RPS=1000
RATELIMIT_BURST=2000

# Default monthly cost budget (USD) applied to tenants without an explicit budget.
DEFAULT_MONTHLY_BUDGET_USD=50

# How many days to retain per-request telemetry logs (TTL index).
TELEMETRY_RETENTION_DAYS=30

# AI provider keys (BYOK — used by the /ai proxy; no markup on tokens).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Shared secret sent to the upstream API as `x-gateway-secret`. Set the SAME
# value on omni-campaign-studio-api to block traffic that bypasses the gateway.
# Rollout: set it here FIRST, then on the API. Leave empty to keep the API open.
GATEWAY_SHARED_SECRET=

# Comma-separated list of allowed CORS origins (localhost:5173 is always allowed).
# IMPORTANT: in production the browser calls the gateway cross-origin, so this
# MUST include the deployed frontend origin or browser requests are CORS-blocked.
ALLOWED_ORIGINS=http://localhost:5173

# Environment
NODE_ENV=development

# Local dev server port (used by src/server.ts)
PORT=8787
